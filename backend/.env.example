# App
APP_NAME=Recap Pro
DEBUG=True

# Database (MongoDB Atlas)
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=recap_pro
REDIS_URL=redis://localhost:6379

# MongoDB Atlas API Keys
MONGODB_ATLAS_PUBLIC_API_KEY=your-public-key
MONGODB_ATLAS_PRIVATE_API_KEY=your-private-key

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="your-private-key"

# API Keys
GEMINI_API_KEY=
GROQ_API_KEY=
ELEVENLABS_API_KEY=

# JWT
SECRET_KEY=change-this-to-random-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS CDN
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CDN_BUCKET=